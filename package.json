{
  "name": "watchenv",
  "version": "1.0.0",
  "private": true,
  "description": "GitLab deployment dashboard for shared staging environments",
  "scripts": {
    "dev": "docker compose up --build",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "migrate": "pnpm --filter backend migrate",
    "studio": "pnpm --filter backend studio"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
